<a-scene
  vr-mode-ui="enabled: false"
  renderer="alpha: true; antialias: true"
  embedded
  arjs="sourceType: webcam; debugUIEnabled: false; detectionMode: mono_and_matrix; matrixCodeType: 3x3;">

  <!-- iluminación de escena para las piezas metálicas (shader standard) -->
  <a-entity light="type: ambient; color:#cdd9e0; intensity:0.62"></a-entity>
  <a-entity light="type: directional; color:#fff3e0; intensity:0.62" position="0.6 1 0.4"></a-entity>
  <a-entity light="type: directional; color:#bfe9ff; intensity:0.28" position="-0.7 0.4 -0.5"></a-entity>
  <a-entity light="type: hemisphere; color:#dfe9ee; groundColor:#1a1f22; intensity:0.35"></a-entity>

  <a-marker preset="hiro" id="hiroMarker">
    <a-entity id="rig" centrifuge-sim position="0 0 0">

      <!-- sombra de contacto (AO simple) -->
      <a-entity id="contactShadow"
        geometry="primitive: circle; segments:32"
        rotation="-90 0 0"
        material="color:#000; shader:flat; transparent:true; opacity:0.38; side:double">
      </a-entity>

      <!-- pies de goma -->
      <a-entity class="foot" geometry="primitive: cylinder; segmentsRadial:8" material="color:#15171a; shader:standard; metalness:0.1; roughness:0.85"></a-entity>
      <a-entity class="foot" geometry="primitive: cylinder; segmentsRadial:8" material="color:#15171a; shader:standard; metalness:0.1; roughness:0.85"></a-entity>
      <a-entity class="foot" geometry="primitive: cylinder; segmentsRadial:8" material="color:#15171a; shader:standard; metalness:0.1; roughness:0.85"></a-entity>
      <a-entity class="foot" geometry="primitive: cylinder; segmentsRadial:8" material="color:#15171a; shader:standard; metalness:0.1; roughness:0.85"></a-entity>

      <!-- carcasa / motor (estática) -->
      <a-entity id="baseHousing"
        geometry="primitive: cylinder; radius:0.17; height:0.025; segmentsRadial:36"
        material="color:#23282c; shader:standard; metalness:0.45; roughness:0.5">
      </a-entity>
      <a-entity id="baseFlange"
        geometry="primitive: torus; segmentsTubular:36"
        material="color:#cfd6db; shader:standard; metalness:0.85; roughness:0.2">
      </a-entity>

      <!-- rejillas de ventilación del motor -->
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>
      <a-entity class="vent" geometry="primitive: box" material="color:#0c0e10; shader:standard; metalness:0.2; roughness:0.7"></a-entity>

      <!-- testigos / placa -->
      <a-entity id="brandPlate"
        text="value: UNIDAD III · CENTRIFUGACIÓN; color:#ff8a00; align:center; width:0.6; baseline:center; shader:msdf">
      </a-entity>
      <a-entity id="statusBezel"
        geometry="primitive: torus; segmentsTubular:20"
        material="color:#0a0c0d; shader:standard; metalness:0.3; roughness:0.6">
      </a-entity>
      <a-entity id="statusLight"
        geometry="primitive: sphere; segmentsWidth:10; segmentsHeight:10"
        material="color:#00e5c7; shader:flat; transparent:true; opacity:0.8"
        light="type: point; color:#00e5c7; intensity:0.4; distance:0.3">
      </a-entity>

      <!-- eje central (referencia, estático) -->
      <a-entity id="shaftAxle"
        geometry="primitive: cylinder; radius:0.003; height:0.3; segmentsRadial:10"
        material="color:#9aa3ad; shader:standard; metalness:0.75; roughness:0.3">
      </a-entity>

      <!-- escudo exterior estático (campana de seguridad transparente) -->
      <a-entity id="outerShield"
        geometry="primitive: cylinder; radius: 0.17; height: 0.23; openEnded: true; segmentsRadial: 32"
        material="color:#dff3ff; opacity:0.045; transparent:true; side:double; shader:flat">
      </a-entity>

      <!-- grupo ROTOR: todo lo que gira visualmente con omega -->
      <a-entity id="drumRotor">

        <a-entity id="rotorFloor"
          geometry="primitive: cylinder; height:0.004; segmentsRadial:28"
          material="color:#aab2b8; shader:standard; metalness:0.65; roughness:0.4">
        </a-entity>

        <a-entity id="hubCone"
          geometry="primitive: cone; segmentsRadial:14"
          material="color:#b9c0c5; shader:standard; metalness:0.8; roughness:0.3">
        </a-entity>

        <a-entity id="drumMesh"
          geometry="primitive: cylinder; radius: 0.15; height: 0.2; openEnded: true; segmentsRadial: 28"
          material="color:#8fd6f2; opacity:0.12; transparent:true; side:double; shader:flat">
        </a-entity>

        <a-entity id="basketMesh"
          geometry="primitive: cylinder; radius: 0.15; height: 0.2; openEnded: true; segmentsRadial: 22; segmentsHeight:10"
          material="color:#cfd6db; shader:standard; metalness:0.6; roughness:0.4; wireframe:true; wireframeLinewidth:1">
        </a-entity>

        <a-entity id="topRing"
          geometry="primitive: torus; radius:0.15; radiusTubular:0.003; segmentsTubular:28"
          material="color:#d7dde1; shader:standard; metalness:0.88; roughness:0.18"
          rotation="90 0 0">
        </a-entity>
        <a-entity id="bottomRing"
          geometry="primitive: torus; radius:0.15; radiusTubular:0.003; segmentsTubular:28"
          material="color:#d7dde1; shader:standard; metalness:0.88; roughness:0.18"
          rotation="90 0 0">
        </a-entity>

        <a-entity class="strut" geometry="primitive: cylinder; radius:0.0015; height:0.2" material="color:#b6bdc2; shader:standard; metalness:0.7; roughness:0.35"></a-entity>
        <a-entity class="strut" geometry="primitive: cylinder; radius:0.0015; height:0.2" material="color:#b6bdc2; shader:standard; metalness:0.7; roughness:0.35"></a-entity>
        <a-entity class="strut" geometry="primitive: cylinder; radius:0.0015; height:0.2" material="color:#b6bdc2; shader:standard; metalness:0.7; roughness:0.35"></a-entity>
        <a-entity class="strut" geometry="primitive: cylinder; radius:0.0015; height:0.2" material="color:#b6bdc2; shader:standard; metalness:0.7; roughness:0.35"></a-entity>
        <a-entity class="strut" geometry="primitive: cylinder; radius:0.0015; height:0.2" material="color:#b6bdc2; shader:standard; metalness:0.7; roughness:0.35"></a-entity>
        <a-entity class="strut" geometry="primitive: cylinder; radius:0.0015; height:0.2" material="color:#b6bdc2; shader:standard; metalness:0.7; roughness:0.35"></a-entity>

        <!-- testigo visual de giro (asimétrico, evidencia la rotación del rotor) -->
        <a-entity id="rimArrow"
          geometry="primitive: box; width:0.015; height:0.015; depth:0.03"
          material="color:#ff8a00; shader:standard; metalness:0.3; roughness:0.4; emissive:#ff8a00; emissiveIntensity:0.25">
        </a-entity>

        <!-- tapa transparente -->
        <a-entity id="lidTop"
          geometry="primitive: cylinder; openEnded:false; segmentsRadial:28"
          material="color:#cdeaf5; opacity:0.16; transparent:true; side:double; shader:flat">
        </a-entity>
        <a-entity id="lidHandle"
          geometry="primitive: cylinder; segmentsRadial:14"
          material="color:#ff8a00; shader:standard; metalness:0.4; roughness:0.4">
        </a-entity>
      </a-entity>

      <!-- fases (geometría radialmente simétrica, no requiere rotar) -->
      <a-entity id="fluidMesh"
        geometry="primitive: cylinder; radius: 0.144; height: 0.2; openEnded: false; segmentsRadial: 20"
        material="color:#1d6f8c; opacity:0.09; transparent:true; shader:flat">
      </a-entity>
      <a-entity id="liquidSurfaceRing"
        geometry="primitive: torus; segmentsTubular:24"
        material="color:#7fe3d4; opacity:0.3; transparent:true; shader:flat">
      </a-entity>

      <a-entity id="particleHolder"></a-entity>

    </a-entity>
  </a-marker>

  <!-- Contenedor estático usado por la "vista lateral": cuando se activa,
       el nodo #rig se traslada aquí (dejando de depender del tracking del
       marcador) y se posiciona con un ángulo lateral fijo, rotable con el
       dedo/mouse. Al desactivar, #rig vuelve a #hiroMarker. -->
  <a-entity id="staticViewHolder" visible="false" position="0 -0.02 -0.42" rotation="8 35 0"></a-entity>

  <a-entity camera></a-entity>
</a-scene>

<!-- ===================== PANEL DE CONTROL ===================== -->
<div id="panel">

  <div id="handleRow">
