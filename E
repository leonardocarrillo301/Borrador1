<style>
  :root{
    --bg-1: #060e1a;
    --bg-2: #0a1628;
    --bg-3: #0d1e34;
    --panel-edge: rgba(255,138,0,.55);
    --bg-readout: #071020;
    --accent: #ff9020;
    --accent-dim: #7a3f08;
    --accent-glow: rgba(255,144,32,.42);
    --cyan: #00e5c7;
    --cyan-dim: #0a6e62;
    --cyan-glow: rgba(0,229,199,.35);
    --blue: #4da6ff;
    --blue-dim: #1a3a6a;
    --blue-glow: rgba(77,166,255,.30);
    --violet: #b06aff;
    --violet-glow: rgba(176,106,255,.25);
    --text: #ddeeff;
    --text-dim: #7a9ab8;
    --text-faint: #4a6680;
    --steel: #c7d8e8;
    --danger: #c9763a;
    --cream: #f2d680;
    --font-d: 'Space Grotesk', -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
    --font-m: 'IBM Plex Mono', "SF Mono", "Courier New", monospace;
    --font-eq: 'Newsreader', Georgia, 'Times New Roman', serif;
  }

  *{ box-sizing: border-box; }

  html, body{
    margin:0; padding:0; height:100%; width:100%;
    background: radial-gradient(ellipse at 30% 20%, #0d2044 0%, #060e1a 55%, #020810 100%);
    font-family: var(--font-d);
    color: var(--text);
    overflow: hidden;
    -webkit-tap-highlight-color: transparent;
  }

  /* Estrellas decorativas de fondo */
  body::before{
    content:"";
    position:fixed; inset:0; z-index:0; pointer-events:none;
    background-image:
      radial-gradient(1px 1px at 15% 25%, rgba(150,200,255,.55) 0%, transparent 100%),
      radial-gradient(1px 1px at 72% 14%, rgba(180,220,255,.45) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 45% 60%, rgba(120,180,255,.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 88% 72%, rgba(150,200,255,.40) 0%, transparent 100%),
      radial-gradient(1px 1px at 28% 82%, rgba(100,160,255,.30) 0%, transparent 100%),
      radial-gradient(2px 2px at 60% 38%, rgba(77,166,255,.20) 0%, transparent 100%);
  }

  a-scene{ position:absolute; top:0; left:0; width:100%; height:100%; }

  :focus-visible{ outline:2px solid var(--cyan); outline-offset:2px; }

  .icon{ width:15px; height:15px; display:inline-block; vertical-align:-3px; margin-right:5px; flex:none; }
  .chev{ transition: transform .25s ease; }

  /* ---------- Barra superior (identidad) ---------- */
  #topBar{
    position:fixed; top:0; left:0; right:0;
    z-index: 22;
    display:flex; align-items:center; justify-content:space-between;
    padding: 9px 12px 7px;
    background: linear-gradient(180deg, rgba(5,7,9,.78) 0%, rgba(5,7,9,0) 100%);
    pointer-events:none;
  }
  #topBar .brand{ display:flex; flex-direction:column; line-height:1.1; }
  #topBar .eyebrow{
    font-size:9px; letter-spacing:2.2px; color: var(--accent);
    font-weight:600; text-transform:uppercase;
  }
  #topBar .title{
    font-size:13.5px; font-weight:600; letter-spacing:.3px; color: var(--text);
  }
  #topBar .rpmChip{
    pointer-events:none;
    display:flex; align-items:baseline; gap:4px;
    background: rgba(8,11,13,.72);
    border:1px solid rgba(255,138,0,.35);
    border-radius:20px;
    padding:5px 11px;
    backdrop-filter: blur(4px);
  }
  #topBar .rpmChip b{
    font-family: var(--font-m); font-size:14px; color: var(--accent);
    text-shadow: 0 0 8px var(--accent-glow);
  }
  #topBar .rpmChip span{ font-size:8.5px; color: var(--text-dim); letter-spacing:1px; }

  /* ---------- Botón de vista lateral (modo 3D sin marcador) ---------- */
  #sideViewBtn{
    pointer-events:auto;
    display:flex; align-items:center; gap:5px;
    background: rgba(8,11,13,.72);
    border:1px solid rgba(0,229,199,.4);
    color: var(--cyan);
    border-radius:20px;
    padding:6px 12px;
    font-family: var(--font-d); font-size:11px; font-weight:600;
    letter-spacing:.3px;
    backdrop-filter: blur(4px);
  }
  #sideViewBtn svg{ width:14px; height:14px; }
  #sideViewBtn.active{
    background: linear-gradient(180deg, #21f3d4, var(--cyan));
    color:#04201c; border-color:transparent;
  }
  #sideViewBtn:active{ transform: translateY(1px); }

  #lateralHint{
    position:fixed; top:54px; left:50%; transform:translateX(-50%);
    z-index:20; display:none;
    background: rgba(8,11,13,.8);
    border:1px solid var(--cyan-dim); color: var(--text);
    padding:6px 13px; border-radius:20px; font-size:11px;
    text-align:center; backdrop-filter: blur(4px);
  }
  #lateralHint.show{ display:block; }

  /* ---------- Aviso de marcador (visor estilo escáner) ---------- */
  #markerHint{
    position:fixed; top:54px; left:50%; transform:translateX(-50%);
    display:flex; flex-direction:column; align-items:center; gap:6px;
    z-index: 20;
    transition: opacity .3s ease;
  }
  #markerHint .frame{
    width:84px; height:84px; position:relative;
  }
  #markerHint .frame i{
    position:absolute; width:18px; height:18px;
    border-color: var(--accent); opacity:.9;
    animation: scanPulse 1.6s infinite ease-in-out;
  }
  #markerHint .frame i:nth-child(1){ top:0; left:0; border-top:2px solid; border-left:2px solid; }
  #markerHint .frame i:nth-child(2){ top:0; right:0; border-top:2px solid; border-right:2px solid; animation-delay:.1s; }
  #markerHint .frame i:nth-child(3){ bottom:0; left:0; border-bottom:2px solid; border-left:2px solid; animation-delay:.2s; }
  #markerHint .frame i:nth-child(4){ bottom:0; right:0; border-bottom:2px solid; border-right:2px solid; animation-delay:.3s; }
  @keyframes scanPulse{ 0%,100%{opacity:.35;} 50%{opacity:1;} }
  #markerHint .txt{
    background: rgba(8,11,13,.8);
    border:1px solid var(--accent-dim);
    color: var(--text);
    padding:6px 13px;
    border-radius: 20px;
    font-size: 11.5px;
    letter-spacing:.2px;
    backdrop-filter: blur(4px);
  }

  @media (prefers-reduced-motion: reduce){
    #markerHint .frame i{ animation:none; }
  }

  /* ---------- Panel inferior ---------- */
  #panel{
    position:fixed; left:0; right:0; bottom:0;
    background: linear-gradient(180deg, rgba(6,14,26,.92) 0%, rgba(4,9,18,.98) 100%);
    border-top: 1px solid rgba(77,166,255,.18);
    padding: 9px 13px calc(9px + env(safe-area-inset-bottom,0px));
    z-index: 10;
    backdrop-filter: blur(10px) saturate(140%);
    box-shadow: 0 -12px 40px rgba(0,20,60,.65), 0 -1px 0 rgba(77,166,255,.10);
  }
  #panel::before{
    content:"";
    position:absolute; top:-1px; left:0; right:0; height:2px;
    background: linear-gradient(90deg, var(--violet) 0%, var(--accent) 30%, var(--cyan) 60%, var(--blue) 100%);
    box-shadow: 0 0 14px rgba(255,138,0,.35), 0 0 28px rgba(0,229,199,.2);
  }

  #handleRow{ display:flex; align-items:center; gap:7px; }

  button{
    font-family: var(--font-d); cursor:pointer; border:none;
    letter-spacing:.4px;
  }
  #pauseBtn{
    flex: 1.4; padding:10px 10px; font-size:14px; font-weight:700;
    border-radius:9px;
    display:flex; align-items:center; justify-content:center;
    background: linear-gradient(180deg, #ff9d24, var(--accent));
    color:#1a1100;
    box-shadow: 0 2px 0 var(--accent-dim), inset 0 1px 0 rgba(255,255,255,.25);
  }
  #pauseBtn.is-paused{
    background: linear-gradient(180deg, #21f3d4, var(--cyan));
    color:#04201c;
    box-shadow: 0 2px 0 #007a69, inset 0 1px 0 rgba(255,255,255,.25);
  }
  #pauseBtn:active{ transform: translateY(2px); box-shadow:none; }
  #pauseBtn .icon-play{ display:none; }
  #pauseBtn.is-paused .icon-pause{ display:none; }
  #pauseBtn.is-paused .icon-play{ display:inline-block; }

  #resetBtn, #panelToggle{
    flex: none; padding:10px 13px; font-size:12px; font-weight:600;
    border-radius:9px; color: var(--text);
    display:flex; align-items:center;
    background: rgba(255,255,255,.04); border:1px solid #2c3338;
    white-space:nowrap;
  }
  #resetBtn:active, #panelToggle:active{ background: rgba(255,255,255,0.1); }
  #panelToggle.is-collapsed .chev{ transform: rotate(180deg); }

  /* cuerpo colapsable */
  #panelBody{
    overflow:hidden;
    max-height: 640px;
    opacity:1;
    transition: max-height .25s ease, opacity .2s ease, margin-top .25s ease;
    margin-top:10px;
  }
  #panelBody.collapsed{
    max-height:0; opacity:0; margin-top:0; pointer-events:none;
  }

  .eyebrow{
    font-size:9.5px; letter-spacing:1.8px; color: var(--text-faint);
    text-transform:uppercase; font-weight:600;
    margin: 2px 0 6px;
    display:flex; align-items:center; gap:6px;
  }
  .eyebrow::after{
    content:""; flex:1; height:1px;
    background: linear-gradient(90deg, #232b2f, transparent);
  }

  #readouts{
    display:grid;
    grid-template-columns: repeat(3, 1fr);
    gap:7px;
    margin-bottom:9px;
  }
  .gauge{
    position:relative;
    background: linear-gradient(160deg, #071528 0%, #040d1a 100%);
    border:1px solid rgba(77,166,255,.20);
    border-radius:8px;
    padding:6px 6px 7px;
    text-align:center;
    box-shadow: inset 0 1px 8px rgba(0,0,0,.6), 0 0 12px rgba(77,166,255,.06);
    overflow:hidden;
  }
  .gauge::before{
    content:""; position:absolute; top:0; left:0; right:0; height:2px;
    background: linear-gradient(90deg, var(--blue), var(--cyan));
    opacity:.65;
  }
  .gauge .lab{
    font-size:8.5px; letter-spacing:1.4px; color: var(--text-dim);
    text-transform:uppercase;
  }
  .gauge .val{
    font-family: var(--font-m);
    font-size: 13.5px; font-weight:500;
    color: var(--cyan);
    text-shadow: 0 0 7px var(--cyan-glow);
    line-height:1.3;
    letter-spacing:0;
    white-space:nowrap;
  }
  .gauge .unit{ font-size:8.5px; color: var(--text-faint); }

  #estado{
    display:flex; align-items:center; gap:8px;
    font-size:11.5px;
    padding:7px 11px;
    border-radius:20px;
    margin-bottom:10px;
    border:1px solid #283034;
    background: rgba(255,255,255,0.025);
  }
  #estado .dot{
    width:8px; height:8px; border-radius:50%; flex:none;
    background: var(--estado-color, var(--text-dim));
    box-shadow: 0 0 8px var(--estado-color, transparent);
  }
  #estado b{ font-weight:600; }

  .ctrl{ margin-bottom:8px; }
  .ctrl-head{
    display:flex; justify-content:space-between; align-items:baseline;
    font-size:12px; margin-bottom:3px;
  }
  .ctrl-head .name{ color: var(--text); font-weight:500; }
  .ctrl-head .live{ font-family: var(--font-m); color: var(--accent); font-size:12.5px; }
  .ctrl.secondary .ctrl-head .live{ color: var(--cyan); }

  input[type=range]{
    -webkit-appearance:none; appearance:none;
    width:100%; height:26px; background:transparent;
  }
  input[type=range]::-webkit-slider-runnable-track{
    height:5px; background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    border-radius:3px;
  }
  input[type=range]::-webkit-slider-thumb{
    -webkit-appearance:none; appearance:none;
    width:19px; height:19px; margin-top:-7.5px;
    border-radius:50%;
    background: radial-gradient(circle at 35% 30%, #fff, var(--text) 60%);
    border:3px solid var(--accent);
    box-shadow: 0 1px 4px rgba(0,0,0,.5);
  }
  .ctrl.secondary input[type=range]::-webkit-slider-runnable-track{
    background: linear-gradient(90deg, var(--cyan-dim), var(--cyan));
  }
  .ctrl.secondary input[type=range]::-webkit-slider-thumb{ border-color: var(--cyan); }

  input[type=range]::-moz-range-track{
    height:5px; background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    border-radius:3px;
  }
  input[type=range]::-moz-range-thumb{
    width:14px; height:14px; border-radius:50%;
    background: var(--text); border:3px solid var(--accent);
  }
  .ctrl.secondary input[type=range]::-moz-range-track{
    background: linear-gradient(90deg, var(--cyan-dim), var(--cyan));
  }
  .ctrl.secondary input[type=range]::-moz-range-thumb{ border-color: var(--cyan); }

  #advToggle{
    font-size:11.5px; color: var(--cyan); font-weight:600;
    display:flex; align-items:center; justify-content:center;
    padding:9px 4px 5px; cursor:pointer; user-select:none;
    border-top: 1px dashed #1f2c2e; margin-top:3px;
  }
  #advToggle.open .chev{ transform: rotate(180deg); }
  #advNote{
    font-size:9.5px; color:var(--text-faint); text-align:center;
    margin:-2px 0 7px;
  }
  #advPanel{
    overflow:hidden; max-height:0; opacity:0;
    transition: max-height .22s ease, opacity .18s ease;
  }
  #advPanel.open{ max-height:480px; opacity:1; margin-top:6px; }

  /* ---------- Fila slider + input numérico ---------- */
  .ctrl-row{ display:flex; align-items:center; gap:8px; }
  .ctrl-row input[type=range]{ flex:1; min-width:0; }
  .numBox{
    flex:none; width:62px;
    font-family: var(--font-m); font-size:12px; text-align:center;
    color: var(--accent); background: var(--bg-readout);
    border:1px solid #2c3338; border-radius:7px;
    padding:5px 3px;
    -moz-appearance: textfield;
  }
  .numBox::-webkit-outer-spin-button,
  .numBox::-webkit-inner-spin-button{ -webkit-appearance:none; margin:0; }
  .ctrl.secondary .numBox{ color: var(--cyan); }
  .numBox:focus{ outline:2px solid var(--accent); outline-offset:1px; }
  .ctrl.secondary .numBox:focus{ outline-color: var(--cyan); }

  /* =====================================================================
     BARRA LATERAL DE NAVEGACIÓN (desplazamiento vertical entre secciones)
     ===================================================================== */
  #sideNav{
    position:fixed; right:6px; top:50%; transform:translateY(-50%);
    z-index:23;
    display:flex; flex-direction:column; gap:8px;
    background: linear-gradient(160deg, rgba(6,20,44,.88) 0%, rgba(4,12,28,.92) 100%);
    border:1px solid rgba(77,166,255,.28);
    border-radius:16px;
    padding:8px 6px;
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 20px rgba(0,10,40,.5), 0 0 0 1px rgba(77,166,255,.08);
  }
  #sideNav button{
    width:34px; height:34px; border-radius:10px;
    background: rgba(77,166,255,.06);
    border:1px solid rgba(77,166,255,.18);
    color: var(--text-dim);
    display:flex; align-items:center; justify-content:center;
    transition: background .15s ease, color .15s ease, border-color .15s ease;
  }
  #sideNav button svg{ width:16px; height:16px; }
  #sideNav button.active{
    background: linear-gradient(160deg, rgba(255,157,36,.22), rgba(255,138,0,.14));
    border-color: var(--accent);
    color: var(--accent);
  }
  #sideNav button:active{ background: rgba(255,255,255,.12); }

  /* secciones del panel + scroll vertical con riel visible */
  #panelScroll{
    max-height: 56vh;
    overflow-y: auto;
    overflow-x: hidden;
    scroll-behavior: smooth;
    padding-right:4px;
  }
  #panelScroll::-webkit-scrollbar{ width:5px; }
  #panelScroll::-webkit-scrollbar-track{ background: rgba(77,166,255,.04); border-radius:4px; }
  #panelScroll::-webkit-scrollbar-thumb{ background: var(--blue-dim); border-radius:4px; }
  #panelScroll::-webkit-scrollbar-thumb:hover{ background: var(--blue); }

  .panelSection{ padding-top:2px; padding-bottom:14px; scroll-margin-top:4px; }
  .panelSection + .panelSection{
    border-top:1px dashed rgba(77,166,255,.18); margin-top:4px; padding-top:14px;
  }
  .sectionTitle{
    font-size:12.5px; font-weight:700; color: var(--text);
    display:flex; align-items:center; gap:7px; margin-bottom:8px;
  }
  .sectionTitle svg{ width:15px; height:15px; color: var(--accent); flex:none; }

  /* ---------- Sección Ecuaciones ---------- */
  .eqCard{
    background: linear-gradient(160deg, #071528 0%, #040e1c 100%);
    border:1px solid rgba(77,166,255,.22);
    border-radius:9px;
    padding:10px 12px 11px;
    margin-bottom:9px;
    box-shadow: 0 2px 12px rgba(0,10,30,.4);
  }
  .eqCard .eqName{ font-size:10.5px; color: var(--text-dim); letter-spacing:.3px; margin-bottom:6px; }
  .eqCard .eqDesc{ font-size:10px; color: var(--text-faint); margin-top:6px; line-height:1.45; }
  .eqCard .eqRange{ font-size:9px; color: var(--text-faint); margin-top:2px; }

  /* --- notación matemática "de verdad": fracciones apiladas, superíndices,
     subíndices, en una tipografía serif de ecuación en vez de una sola
     línea monoespaciada --- */
  .eqFormula{
    font-family: var(--font-eq); font-style:italic; font-size:15px;
    color: var(--cyan);
    display:flex; align-items:center; gap:7px; flex-wrap:wrap;
    overflow-x:auto; padding-bottom:2px;
  }
  .eqFormula .eqSign{ font-style:normal; opacity:.85; }
  .eqFormula sup{ font-size:.62em; line-height:0; }
  .eqFormula sub{ font-size:.62em; line-height:0; }
  .eqFrac{
    display:inline-flex; flex-direction:column; align-items:center;
    vertical-align:middle; margin:0 1px;
  }
  .eqFrac .num, .eqFrac .den{
    padding:0 5px; white-space:nowrap;
  }
  .eqFrac .num{ border-bottom:1.4px solid var(--cyan); padding-bottom:2px; }
  .eqFrac .den{ padding-top:2px; }
  .eqLn{ font-style:italic; }
  .eqLn .arg{ font-style:italic; }

  /* ---------- Nota de rango bajo cada slider ---------- */
  .rangeNote{
    font-family: var(--font-m); font-size:9px; color: var(--text-faint);
    margin-top:3px; letter-spacing:.2px;
  }
  .rangeNote b{ color: var(--text-dim); font-weight:600; }

  /* ---------- Botón repetir simulación ---------- */
  #repeatBtn{
    width:100%; padding:10px 6px; font-size:12.5px; font-weight:700;
    border-radius:9px; color:#04201c;
    display:flex; align-items:center; justify-content:center; gap:7px;
    background: linear-gradient(180deg, #21f3d4, var(--cyan));
    box-shadow: 0 2px 0 #007a69, inset 0 1px 0 rgba(255,255,255,.25);
    margin-top:4px;
  }
  #repeatBtn:active{ transform: translateY(2px); box-shadow:none; }
  #repeatBtn svg{ width:14px; height:14px; }
  #repeatBtn[hidden]{ display:none; }

  /* =====================================================================
     CALCULADORA DE PARÁMETROS DE CENTRIFUGACIÓN
     ===================================================================== */
  .calcGrid{
    display:grid; grid-template-columns: 1fr 1fr; gap:7px;
    margin-bottom:10px;
  }
  .calcField{
    display:flex; flex-direction:column; gap:3px;
  }
  .calcField label{
    font-size:9.5px; color: var(--text-dim); letter-spacing:.8px;
    text-transform:uppercase; font-weight:600;
  }
  .calcField input{
    font-family: var(--font-m); font-size:12px; text-align:center;
    color: var(--blue); background: linear-gradient(160deg, #071528, #040e1c);
    border:1px solid rgba(77,166,255,.30); border-radius:7px;
    padding:7px 4px;
    -moz-appearance: textfield;
    transition: border-color .15s, box-shadow .15s;
  }
  .calcField input:focus{
    outline:none; border-color: var(--blue);
    box-shadow: 0 0 0 2px rgba(77,166,255,.18);
  }
  .calcField input::-webkit-outer-spin-button,
  .calcField input::-webkit-inner-spin-button{ -webkit-appearance:none; margin:0; }
  .calcField .unit{
    font-size:8.5px; color: var(--text-faint); text-align:center; margin-top:-1px;
  }

  #calcBtn{
    width:100%; padding:10px 6px; font-size:13px; font-weight:700;
    border-radius:9px; color:#020c1a;
    display:flex; align-items:center; justify-content:center; gap:7px;
    background: linear-gradient(180deg, #5ec0ff, var(--blue));
    box-shadow: 0 2px 0 var(--blue-dim), inset 0 1px 0 rgba(255,255,255,.25);
    margin-bottom:10px;
  }
  #calcBtn:active{ transform: translateY(2px); box-shadow:none; }
  #calcBtn svg{ width:14px; height:14px; }

  #calcResults{
    display:grid; grid-template-columns: repeat(2,1fr); gap:7px;
    display:none;
  }
  #calcResults.visible{ display:grid; }
  .calcOut{
    position:relative; overflow:hidden;
    background: linear-gradient(160deg, #071e3a 0%, #040c1e 100%);
    border:1px solid rgba(77,166,255,.28);
    border-radius:9px; padding:7px 8px 8px; text-align:center;
    box-shadow: 0 0 16px rgba(77,166,255,.08);
  }
  .calcOut::before{
    content:""; position:absolute; top:0; left:0; right:0; height:2px;
    background: linear-gradient(90deg, var(--blue), var(--violet));
  }
  .calcOut .co-lab{
    font-size:8.5px; letter-spacing:1.2px; color: var(--text-dim); text-transform:uppercase;
  }
  .calcOut .co-val{
    font-family: var(--font-m); font-size:13.5px; font-weight:500;
    color: var(--blue);
    text-shadow: 0 0 8px var(--blue-glow);
    line-height:1.35;
    white-space:nowrap;
  }
  .calcOut.highlight .co-val{
    color: var(--cyan);
    text-shadow: 0 0 8px var(--cyan-glow);
    font-size:15px;
  }
  .calcOut .co-unit{ font-size:8px; color: var(--text-faint); }
  .calcNote{
    font-size:9px; color: var(--text-faint); text-align:center; margin-top:6px;
    line-height:1.4;
  }
</style>
</head>

