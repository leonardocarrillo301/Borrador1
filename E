    </section>

    <!-- ============ SECCIÓN: EQUIPO / VARIABLES DEL SIMULADOR ============ -->
    <section class="panelSection" id="secEquipo">
      <div class="sectionTitle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Equipo / variables principales
      </div>

      <div class="ctrl">
        <div class="ctrl-head">
          <span class="name">Velocidad angular (N)</span>
          <span class="live"><span id="rpmLive">4000</span> RPM</span>
        </div>
        <div class="ctrl-row">
          <input type="range" id="rpmSlider" min="500" max="12000" step="100" value="4000">
          <input type="number" id="rpmInput" class="numBox" min="500" max="12000" step="100" value="4000">
        </div>
        <div class="rangeNote">Rango admitido: <b>500 – 12 000 RPM</b></div>
      </div>

      <div class="ctrl">
        <div class="ctrl-head">
          <span class="name">Radio del tambor (r)</span>
          <span class="live"><span id="rLive">0.15</span> m</span>
        </div>
        <div class="ctrl-row">
          <input type="range" id="rSlider" min="0.05" max="0.50" step="0.01" value="0.15">
          <input type="number" id="rInput" class="numBox" min="0.05" max="0.50" step="0.01" value="0.15">
        </div>
        <div class="rangeNote">Rango admitido: <b>0.05 – 0.50 m</b></div>
      </div>

      <div id="advToggle">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Parámetros avanzados (μ)
        <svg class="icon chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0;margin-left:5px;"><path d="M6 9l6 6 6-6"/></svg>
      </div>
      <div id="advNote">Auxiliar del fluido — no es variable obligatoria del taller</div>
      <div id="advPanel">
        <div class="ctrl secondary">
          <div class="ctrl-head">
            <span class="name">Viscosidad (μ)</span>
            <span class="live"><span id="muLive">1.0</span> mPa·s</span>
          </div>
          <div class="ctrl-row">
            <input type="range" id="muSlider" min="0.1" max="500" step="0.1" value="1.0">
            <input type="number" id="muInput" class="numBox" min="0.1" max="500" step="0.1" value="1.0">
          </div>
          <div class="rangeNote">Rango admitido: <b>0.1 – 500 mPa·s</b> (0.1 ≈ agua tibia · 500 ≈ jarabe espeso)</div>
        </div>
      </div>
    </section>

    <!-- ============ SECCIÓN: PARTÍCULA / SUSTANCIA SÓLIDA ============ -->
    <section class="panelSection" id="secParticula">
      <div class="sectionTitle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="2.2" fill="currentColor" stroke="none"/></svg>
        Partícula / sustancia sólida
      </div>

      <div class="ctrl">
        <div class="ctrl-head">
          <span class="name">Δρ = ρp − ρf</span>
          <span class="live"><span id="dRhoLive">600</span> kg/m³</span>
        </div>
        <div class="ctrl-row">
          <input type="range" id="dRhoSlider" min="-1000" max="2000" step="10" value="600">
          <input type="number" id="dRhoInput" class="numBox" min="-1000" max="2000" step="10" value="600">
        </div>
        <div class="rangeNote">Rango admitido: <b>−1000 – 2000 kg/m³</b> (negativo = partícula flota hacia el eje)</div>
      </div>

      <div class="ctrl secondary">
        <div class="ctrl-head">
          <span class="name">Diámetro (d<sub>p</sub>)</span>
          <span class="live"><span id="dpLive">10</span> µm</span>
        </div>
        <div class="ctrl-row">
          <input type="range" id="dpSlider" min="1" max="200" step="1" value="10">
          <input type="number" id="dpInput" class="numBox" min="1" max="200" step="1" value="10">
        </div>
        <div class="rangeNote">Rango admitido: <b>1 – 200 µm</b></div>
      </div>
      <div class="ctrl-note" style="font-size:9.5px; color:var(--text-faint); margin:-2px 0 4px;">
        El tamaño visual de la partícula en el simulador AR escala con d<sub>p</sub>.
      </div>
    </section>

    <!-- ============ SECCIÓN: ECUACIONES GOBERNANTES ============ -->
    <section class="panelSection" id="secEcuaciones">
      <div class="sectionTitle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19h16"/><path d="M7 15l3-7 3 5 2-4 2 6" /></svg>
        Ecuaciones gobernantes
      </div>

      <div class="eqCard">
        <div class="eqName">1 · Velocidad angular</div>
        <div class="eqFormula">
          <span>ω</span><span class="eqSign">=</span>
          <span class="eqFrac"><span class="num">2π · N</span><span class="den">60</span></span>
        </div>
        <div class="eqDesc">N = velocidad de rotación del tambor (RPM) → ω resulta en rad/s.</div>
        <div class="eqRange">N admitido en este taller: 500 – 12 000 RPM</div>
      </div>

      <div class="eqCard">
        <div class="eqName">2 · Factor de separación centrífugo</div>
        <div class="eqFormula">
          <span>G</span><span class="eqSign">=</span>
          <span class="eqFrac"><span class="num">ω<sup>2</sup> · r</span><span class="den">g</span></span>
        </div>
        <div class="eqDesc">Adimensional; compara la aceleración centrífuga con la gravedad. g = 9.81 m/s² (constante).</div>
        <div class="eqRange">r admitido: 0.05 – 0.50 m</div>
      </div>

      <div class="eqCard">
        <div class="eqName">3 · Velocidad terminal de migración (Stokes-centrífuga)</div>
        <div class="eqFormula">
          <span>v<sub>t</sub></span><span class="eqSign">=</span>
          <span class="eqFrac"><span class="num">d<sub>p</sub><sup>2</sup> · (ρ<sub>p</sub> − ρ<sub>f</sub>) · ω<sup>2</sup> · r</span><span class="den">18 · μ</span></span>
        </div>
        <div class="eqDesc">v<sub>t</sub> &gt; 0: sedimentación hacia la pared del tambor · v<sub>t</sub> &lt; 0: flotación hacia el eje. Válida en régimen laminar (Re<sub>p</sub> &lt; 0.5, ver ecuación 5).</div>
        <div class="eqRange">Δρ admitido: −1000 – 2000 kg/m³ · d<sub>p</sub> admitido: 1 – 200 µm</div>
      </div>

      <div class="eqCard">
        <div class="eqName">4 · Caída de presión radial en la fase líquida</div>
        <div class="eqFormula">
          <span>ΔP</span><span class="eqSign">=</span>
          <span class="eqFrac"><span class="num">ρ<sub>f</sub> · ω<sup>2</sup> · (r<sub>2</sub><sup>2</sup> − r<sub>1</sub><sup>2</sup>)</span><span class="den">2</span></span>
        </div>
        <div class="eqDesc">Presión hidrostática generada por el campo centrífugo entre dos radios r₁ (interior) y r₂ (exterior) de la columna de líquido — análogo centrífugo de ΔP = ρ·g·h.</div>
        <div class="eqRange">r₁, r₂ dentro del radio del tambor: 0.05 – 0.50 m</div>
      </div>

      <div class="eqCard">
        <div class="eqName">5 · Número de Reynolds de partícula</div>
        <div class="eqFormula">
          <span>Re<sub>p</sub></span><span class="eqSign">=</span>
          <span class="eqFrac"><span class="num">ρ<sub>f</sub> · |v<sub>t</sub>| · d<sub>p</sub></span><span class="den">μ</span></span>
        </div>
        <div class="eqDesc">Verifica si aplica la Ley de Stokes: se requiere Re<sub>p</sub> &lt; 0.5 (régimen laminar). Con Re<sub>p</sub> mayor, v<sub>t</sub> queda sobreestimada y haría falta un coeficiente de arrastre corregido.</div>
        <div class="eqRange">Calculado con los mismos μ, d<sub>p</sub> y ρ<sub>f</sub> del taller.</div>
      </div>

      <div class="eqCard">
        <div class="eqName">6 · Tiempo de sedimentación</div>
        <div class="eqFormula">
          <span>t</span><span class="eqSign">=</span>
          <span class="eqFrac"><span class="num">18 · μ</span><span class="den">d<sub>p</sub><sup>2</sup> · Δρ · ω<sup>2</sup></span></span>
          <span class="eqSign">·</span>
          <span class="eqLn">ln<span class="arg">(r<sub>o</sub> / r<sub>i</sub>)</span></span>
        </div>
        <div class="eqDesc">Integración exacta de la ecuación de Stokes-centrífuga entre el radio interior de la partícula r<sub>i</sub> y el radio de la pared r<sub>o</sub>. Es el tiempo mínimo teórico de residencia para lograr la separación completa de esa partícula.</div>
        <div class="eqRange">En este simulador: r<sub>i</sub> = 0.10·r · r<sub>o</sub> = 0.93·r</div>
      </div>

      <div class="ctrl-note" style="font-size:9.5px; color:var(--text-faint); text-align:center; margin-top:2px;">
        Referencia: McCabe, Smith &amp; Harriott / Geankoplis — Operaciones Unitarias.
      </div>
    </section>

    <!-- ============ SECCIÓN: CALCULADORA DE CENTRIFUGACIÓN ============ -->
    <section class="panelSection" id="secCalculadora">
      <div class="sectionTitle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--blue)"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="14" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="16" y2="18"/></svg>
        Calculadora de centrifugación
      </div>

      <div class="calcGrid">
        <div class="calcField">
          <label>ρ<sub>p</sub> — densidad partícula</label>
          <input type="number" id="c_rhoP" value="1600" min="100" max="20000" step="10">
          <span class="unit">kg/m³ · rango 100–20 000</span>
        </div>
        <div class="calcField">
          <label>ρ<sub>f</sub> — densidad fluido</label>
          <input type="number" id="c_rhoF" value="1000" min="100" max="5000" step="10">
          <span class="unit">kg/m³ · rango 100–5000</span>
        </div>
        <div class="calcField">
          <label>d<sub>p</sub> — diámetro partícula</label>
          <input type="number" id="c_dp" value="10" min="0.1" max="5000" step="0.1">
          <span class="unit">µm · rango 0.1–5000</span>
        </div>
        <div class="calcField">
          <label>N — velocidad de rotación</label>
          <input type="number" id="c_rpm" value="4000" min="100" max="50000" step="100">
          <span class="unit">RPM · rango 100–50 000</span>
        </div>
        <div class="calcField">
          <label>r — radio del tambor</label>
          <input type="number" id="c_r" value="0.15" min="0.01" max="2" step="0.01">
          <span class="unit">m · rango 0.01–2</span>
        </div>
        <div class="calcField">
          <label>μ — viscosidad fluido</label>
          <input type="number" id="c_mu" value="1.0" min="0.001" max="10000" step="0.1">
          <span class="unit">mPa·s · rango 0.001–10 000</span>
        </div>
      </div>
      <p class="calcNote" style="margin-top:-3px; margin-bottom:9px;">
        Estos campos aceptan cualquier valor dentro del rango indicado; no están limitados a las mismas cotas de los sliders del simulador AR (esta calculadora es de propósito general).
      </p>

      <button id="calcBtn" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Calcular parámetros
      </button>

      <div id="calcResults">
        <div class="calcOut">
          <div class="co-lab">ω angular</div>
          <div class="co-val" id="co_omega">—</div>
          <div class="co-unit">rad/s</div>
        </div>
        <div class="calcOut">
          <div class="co-lab">Factor G</div>
          <div class="co-val" id="co_G">—</div>
          <div class="co-unit">adimensional</div>
        </div>
        <div class="calcOut">
          <div class="co-lab">Δρ</div>
          <div class="co-val" id="co_dRho">—</div>
          <div class="co-unit">kg/m³</div>
        </div>
        <div class="calcOut">
          <div class="co-lab">v<sub>t</sub> migración</div>
          <div class="co-val" id="co_vt">—</div>
          <div class="co-unit">mm/s</div>
        </div>
        <div class="calcOut" style="grid-column:1/-1">
          <div class="co-lab">Re partícula (verificación Stokes)</div>
          <div class="co-val" id="co_Re">—</div>
          <div class="co-unit">adim · Stokes válido si Re &lt; 0.5</div>
        </div>
        <div class="calcOut highlight" style="grid-column:1/-1">
          <div class="co-lab">⏱ Tiempo de sedimentación estimado</div>
          <div class="co-val" id="co_tsed">—</div>
          <div class="co-unit" id="co_tsed_unit">s</div>
        </div>
      </div>
      <div id="calcError" style="display:none; color:#ff6b6b; font-size:10.5px; text-align:center; margin-top:6px;"></div>
      <p class="calcNote">
        t<sub>sed</sub> se calcula integrando la ec. de Stokes-centrífuga desde r<sub>i</sub> hasta r<sub>o</sub>:<br>
        t = [18μ / (d<sub>p</sub>² · Δρ · ω²)] · ln(r<sub>o</sub> / r<sub>i</sub>)
      </p>
    </section>

    </div><!-- /panelScroll -->
  </div>
</div>

<script>
(function(){

  // ---------------- Constante física fija ----------------
  var G_GRAV = 9.81;        // m/s2

  // ---------------- Escalas de visualización -----------------
  // La rotación visual del rotor y el desplazamiento radial de las
  // partículas en pantalla están ligados matemáticamente a omega y v_t
  // reales mediante un único factor de escala (SPEED_VIS_SCALE), igual
  // para ambos movimientos. Así, si una partícula tiene una v_t real
  // mayor que otra, también se verá moverse más rápido en pantalla,
  // en la misma proporción (no hay recorte/clamp que distorsione la
  // relación entre partículas). Los valores numéricos del panel
  // (omega, G, v_t) siempre corresponden al cálculo físico exacto.
  var ANGULAR_VIS_SCALE = 80;     // divide a omega real para obtener spin visible
  var SPEED_VIS_SCALE   = 0.12;   // escala la v_t real a velocidad visual de pantalla
  var RADIAL_VIS_MIN    = 0.005;  // velocidad visual mínima (m/s) cuando hay separación,
                                  // para que siempre se note movimiento (≈ 25 s a r=0.15)
  var RADIAL_VIS_MAX    = 0.022;  // velocidad visual máxima (m/s), evita que sea instantáneo
  var N_PARTICLES = 18;           // partículas visuales de la sustancia activa
  var N_STRUTS = 6, N_FEET = 4, N_VENTS = 10;

  // tamaño visual de partícula: escala real con d_p (µm), acotado a un
  // rango perceptible en AR (1 µm -> esfera mínima, 200 µm -> máxima)
  var PARTICLE_VIS_MIN = 0.004;   // m, radio visual mínimo
  var PARTICLE_VIS_MAX = 0.016;   // m, radio visual máximo
  var DP_MIN = 1, DP_MAX = 200;   // rango de los sliders de d_p (µm)

  var SUBSTANCE_COLOR = '#ff8a00';

  // ---------------- Estado global de simulación ---------------
  var SIM = {
    paused: false,
    finished: false,           // true cuando todas las partículas ya llegaron a su destino
    substance: null            // { dRho, dp_um, color, particles:[{radius,angle,y,el,arrived}], accumulation, lastSign }
  };

  // ---------------- DOM refs -----------------------------------
  var rpmSlider  = document.getElementById('rpmSlider');
  var rSlider    = document.getElementById('rSlider');
  var muSlider   = document.getElementById('muSlider');
  var dRhoSlider = document.getElementById('dRhoSlider');
  var dpSlider   = document.getElementById('dpSlider');

  var rpmInput   = document.getElementById('rpmInput');
  var rInput     = document.getElementById('rInput');
  var muInput    = document.getElementById('muInput');
  var dRhoInput  = document.getElementById('dRhoInput');
  var dpInput    = document.getElementById('dpInput');

  var rpmLive  = document.getElementById('rpmLive');
  var rLive    = document.getElementById('rLive');
  var muLive   = document.getElementById('muLive');
  var dRhoLive = document.getElementById('dRhoLive');
  var dpLive   = document.getElementById('dpLive');
  var rpmChipVal = document.getElementById('rpmChipVal');

  var omegaVal = document.getElementById('omegaVal');
  var gVal     = document.getElementById('gVal');
  var vtVal    = document.getElementById('vtVal');
  var estadoTxt= document.getElementById('estadoTxt');
  var estadoBox= document.getElementById('estado');

  var pauseBtn = document.getElementById('pauseBtn');
  var pauseLabel = document.getElementById('pauseLabel');
  var resetBtn = document.getElementById('resetBtn');
  var repeatBtn = document.getElementById('repeatBtn');
  var panelToggle = document.getElementById('panelToggle');
  var panelToggleLabel = document.getElementById('panelToggleLabel');
  var panelBody = document.getElementById('panelBody');
  var panelScroll = document.getElementById('panelScroll');
  var advToggle = document.getElementById('advToggle');
  var advPanel = document.getElementById('advPanel');
  var markerHint = document.getElementById('markerHint');
  var sideNavBtns = document.querySelectorAll('#sideNav button');

  var sideViewBtn = document.getElementById('sideViewBtn');
  var sideViewLabel = document.getElementById('sideViewLabel');
  var lateralHint = document.getElementById('lateralHint');
  var staticViewHolder = document.getElementById('staticViewHolder');
  var hiroMarkerEl = document.getElementById('hiroMarker');
  var sceneEl = document.querySelector('a-scene');

  // ---------------- Cálculo de variables físicas ----------------
  function computeOmegaG(rpm, r){
    var omega = (rpm * 2 * Math.PI) / 60;             // rad/s
    var G = (omega * omega * r) / G_GRAV;                // adimensional
    return { omega: omega, G: G };
  }

  function computeVt(omega, r, dRho, dp_m, mu_pas){
    return (dp_m*dp_m * dRho * omega*omega * r) / (18 * mu_pas); // m/s, con signo
  }

  function currentEquipmentInputs(){
    return {
      rpm: parseFloat(rpmSlider.value),
      r:   parseFloat(rSlider.value),
      mu_mpas: parseFloat(muSlider.value)
    };
  }

  function updateReadouts(){
    var eq = currentEquipmentInputs();
    var og = computeOmegaG(eq.rpm, eq.r);

    omegaVal.textContent = og.omega.toFixed(3);
    gVal.textContent = og.G.toFixed(3);

    var sub = SIM.substance;
    if (sub){
      var dp_m = sub.dp_um * 1e-6;
      var mu_pas = eq.mu_mpas * 1e-3;
      var vt = computeVt(og.omega, eq.r, sub.dRho, dp_m, mu_pas);
      vtVal.textContent = (vt*1000).toFixed(3); // mm/s
    } else {
      vtVal.textContent = '0.000';
    }

    rpmLive.textContent = eq.rpm.toFixed(0);
    rpmChipVal.textContent = eq.rpm.toFixed(0);
    rLive.textContent = eq.r.toFixed(2);
    muLive.textContent = eq.mu_mpas.toFixed(1);

    syncNumberFromSlider(rpmSlider, rpmInput);
    syncNumberFromSlider(rSlider, rInput);
    syncNumberFromSlider(muSlider, muInput);
    if (sub){
      syncNumberFromSlider(dRhoSlider, dRhoInput);
      syncNumberFromSlider(dpSlider, dpInput);
    }

    var estado, color;
    if (SIM.finished){
      estado = 'Simulación completa · todas las partículas alcanzaron su destino';
      color = '#7fe3d4';
    } else if (!sub || Math.abs(sub.dRho) < 5){
      estado = 'Suspensión neutra · sin separación neta (Δρ ≈ 0)';
      color = '#8fa8b8';
    } else if (sub.dRho > 0){
      estado = 'Sedimentación · partícula migra hacia la pared (ρp > ρf)';
      color = '#c9763a';
    } else {
      estado = 'Flotación / cremado · partícula migra al centro (ρp < ρf)';
      color = '#f2d680';
    }
    estadoTxt.textContent = estado;
    estadoTxt.style.color = color;
    estadoBox.style.setProperty('--estado-color', color);

    return { eq: eq, og: og };
  }

  // ---------------- Sincronización slider <-> input numérico ----------------
  function syncNumberFromSlider(slider, numInput){
    if (document.activeElement !== numInput){
      numInput.value = slider.value;
    }
  }

  function clamp(val, min, max){
    return Math.max(min, Math.min(max, val));
  }

  function bindSliderNumberPair(slider, numInput, onChange){
    slider.addEventListener('input', function(){
      numInput.value = slider.value;
      onChange();
    });
    numInput.addEventListener('input', function(){
      var v = parseFloat(numInput.value);
      if (!isNaN(v)){
        slider.value = clamp(v, parseFloat(slider.min), parseFloat(slider.max));
        onChange();
      }
    });
    numInput.addEventListener('blur', function(){
      var min = parseFloat(numInput.min), max = parseFloat(numInput.max);
      var v = parseFloat(numInput.value);
      if (isNaN(v)) v = parseFloat(slider.value);
      v = clamp(v, min, max);
      numInput.value = v;
      slider.value = v;
      onChange();
    });
    numInput.addEventListener('keydown', function(e){
      if (e.key === 'Enter') numInput.blur();
    });
  }

  // ---------------- Geometría del tambor y del rotor (depende de r) ----------------
  function updateDrumGeometry(r){
    var h = r * 1.3;

    var drum  = document.getElementById('drumMesh');
    var basket= document.getElementById('basketMesh');
    var fluid = document.getElementById('fluidMesh');
    var surf  = document.getElementById('liquidSurfaceRing');
    var topRing = document.getElementById('topRing');
    var bottomRing = document.getElementById('bottomRing');
    var rimArrow = document.getElementById('rimArrow');
    var shaft = document.getElementById('shaftAxle');
    var base = document.getElementById('baseHousing');
    var flange = document.getElementById('baseFlange');
    var light = document.getElementById('statusLight');
    var bezel = document.getElementById('statusBezel');
    var plate = document.getElementById('brandPlate');
    var shield = document.getElementById('outerShield');
    var rotorFloor = document.getElementById('rotorFloor');
    var hub = document.getElementById('hubCone');
    var lid = document.getElementById('lidTop');
    var lidHandle = document.getElementById('lidHandle');
    var shadow = document.getElementById('contactShadow');

    drum.setAttribute('geometry', 'primitive: cylinder; radius: ' + r + '; height: ' + h + '; openEnded: true; segmentsRadial: 28');
    basket.setAttribute('geometry', 'primitive: cylinder; radius: ' + (r*1.001) + '; height: ' + (h*0.999) + '; openEnded: true; segmentsRadial: 22; segmentsHeight: 10');
    fluid.setAttribute('geometry', 'primitive: cylinder; radius: ' + (r*0.96) + '; height: ' + h + '; openEnded: false; segmentsRadial: 20');
    if (SIM.substance) updateSubstanceRingGeometry(SIM.substance, r);

    var tube = r*0.018;
    topRing.setAttribute('geometry', 'primitive: torus; radius:' + r + '; radiusTubular:' + tube + '; segmentsTubular:28');
    topRing.setAttribute('position', '0 ' + (h/2) + ' 0');
    bottomRing.setAttribute('geometry', 'primitive: torus; radius:' + r + '; radiusTubular:' + tube + '; segmentsTubular:28');
    bottomRing.setAttribute('position', '0 ' + (-h/2) + ' 0');

    var struts = document.querySelectorAll('.strut');
    for (var i=0; i<struts.length; i++){
      var ang = i * (2*Math.PI/N_STRUTS);
      var sx = r*Math.cos(ang);
      var sz = r*Math.sin(ang);
      struts[i].setAttribute('geometry', 'primitive: cylinder; radius:' + (r*0.012) + '; height:' + h);
      struts[i].setAttribute('position', sx + ' 0 ' + sz);
    }

    rimArrow.setAttribute('geometry', 'primitive: box; width:' + (r*0.1) + '; height:' + (r*0.1) + '; depth:' + (r*0.22));
    rimArrow.setAttribute('position', (r*1.05) + ' ' + (h/2) + ' 0');

    var lidH = r*0.035;
    lid.setAttribute('geometry', 'primitive: cylinder; radius:' + (r*0.97) + '; height:' + lidH + '; openEnded:false; segmentsRadial:28');
    var lidY = (h/2) + (lidH/2) + 0.002;
    lid.setAttribute('position', '0 ' + lidY + ' 0');
    var handleH = r*0.09;
    lidHandle.setAttribute('geometry', 'primitive: cylinder; radius:' + (r*0.05) + '; height:' + handleH + '; segmentsRadial:14');
    lidHandle.setAttribute('position', '0 ' + (lidY + (lidH/2) + (handleH/2)) + ' 0');

    rotorFloor.setAttribute('geometry', 'primitive: cylinder; radius:' + (r*0.92) + '; height:' + (r*0.015) + '; segmentsRadial:28');
    rotorFloor.setAttribute('position', '0 ' + (-(h/2) + r*0.02) + ' 0');
    var hubH = r*0.1;
    hub.setAttribute('geometry', 'primitive: cone; radiusBottom:' + (r*0.025) + '; radiusTop:' + (r*0.065) + '; height:' + hubH + '; segmentsRadial:14');
    hub.setAttribute('position', '0 ' + (-(h/2) + r*0.02 + hubH*0.45) + ' 0');

    var shaftH = h*1.05;
    shaft.setAttribute('geometry', 'primitive: cylinder; radius:' + (r*0.018) + '; height:' + shaftH + '; segmentsRadial:10');
    shaft.setAttribute('position', '0 0 0');

    shield.setAttribute('geometry', 'primitive: cylinder; radius:' + (r*1.15) + '; height:' + (h*1.12) + '; openEnded: true; segmentsRadial: 32');

    surf.setAttribute('geometry', 'primitive: torus; radius:' + (r*0.93) + '; radiusTubular:' + (r*0.006) + '; segmentsTubular:24');
    surf.setAttribute('rotation', '90 0 0');
    surf.setAttribute('position', '0 ' + (h*0.46) + ' 0');

    var baseR = r*1.18;
    var baseH = r*0.20;
    base.setAttribute('geometry', 'primitive: cylinder; radius:' + baseR + '; height:' + baseH + '; segmentsRadial:36');
    var baseY = -(h/2) - (baseH/2) - 0.004;
    base.setAttribute('position', '0 ' + baseY + ' 0');
    var baseTopY = baseY + baseH/2;

    flange.setAttribute('geometry', 'primitive: torus; radius:' + (baseR*0.985) + '; radiusTubular:' + (r*0.012) + '; segmentsTubular:36');
    flange.setAttribute('position', '0 ' + (baseTopY) + ' 0');
    flange.setAttribute('rotation', '90 0 0');

    var feet = document.querySelectorAll('.foot');
    var footR = r*0.035, footH = r*0.05;
    for (var f=0; f<feet.length; f++){
      var fang = f*(2*Math.PI/N_FEET) + Math.PI/4;
      var fx = baseR*0.78*Math.cos(fang);
      var fz = baseR*0.78*Math.sin(fang);
      feet[f].setAttribute('geometry', 'primitive: cylinder; radius:' + footR + '; height:' + footH + '; segmentsRadial:8');
      feet[f].setAttribute('position', fx + ' ' + (baseY - baseH/2 - footH/2) + ' ' + fz);
    }

    var vents = document.querySelectorAll('.vent');
    var ventW = r*0.05, ventH = baseH*0.55, ventD = r*0.012;
    for (var vIdx=0; vIdx<vents.length; vIdx++){
      var vang = vIdx*(2*Math.PI/N_VENTS);
      var vx = baseR*0.985*Math.cos(vang);
      var vz = baseR*0.985*Math.sin(vang);
      vents[vIdx].setAttribute('geometry', 'primitive: box; width:' + ventW + '; height:' + ventH + '; depth:' + ventD);
      vents[vIdx].setAttribute('position', vx + ' ' + baseTopY + ' ' + vz);
      vents[vIdx].setAttribute('rotation', '0 ' + (-vang*180/Math.PI) + ' 0');
    }

    plate.setAttribute('position', '0 ' + (baseY + 0.001) + ' ' + (baseR*0.92));
    plate.setAttribute('scale', (r*0.55) + ' ' + (r*0.55) + ' ' + (r*0.55));

    var lightR = r*0.028;
    light.setAttribute('geometry', 'primitive: sphere; radius:' + lightR + '; segmentsWidth:10; segmentsHeight:10');
    var lightX = baseR*0.6, lightZ = 0, lightY = baseTopY + lightR + 0.001;
    light.setAttribute('position', lightX + ' ' + lightY + ' ' + lightZ);
    bezel.setAttribute('geometry', 'primitive: torus; radius:' + (lightR*1.7) + '; radiusTubular:' + (lightR*0.35) + '; segmentsTubular:20');
    bezel.setAttribute('position', lightX + ' ' + (lightY-0.001) + ' ' + lightZ);
    bezel.setAttribute('rotation', '90 0 0');

    shadow.setAttribute('geometry', 'primitive: circle; radius:' + (baseR*1.35) + '; segments:32');
    shadow.setAttribute('position', '0 ' + (baseY - baseH/2 - footH - 0.003) + ' 0');
  }

  function limits(r){
    return { inner: r*0.10, outer: r*0.93, height: r*1.3 };
  }

  function particleColor(dRho, fallbackColor){
    if (Math.abs(dRho) < 5) return '#8FA8B8';
    return fallbackColor;
  }

  // tamaño visual de la esfera (m) en función real de d_p (µm)
  function particleVisualRadius(dp_um){
    var t = clamp((dp_um - DP_MIN) / (DP_MAX - DP_MIN), 0, 1);
    return PARTICLE_VIS_MIN + t * (PARTICLE_VIS_MAX - PARTICLE_VIS_MIN);
  }

  function applyParticleSize(sub){
    var rad = particleVisualRadius(sub.dp_um);
    for (var i=0;i<sub.particles.length;i++){
      sub.particles[i].el.setAttribute('geometry', 'primitive: sphere; radius: ' + rad + '; segmentsWidth:10; segmentsHeight:8');
    }
  }

  // ---------------- Creación de la sustancia activa ----------------
  function createSubstance(dRho, dp_um){
    var sub = {
      dRho: (typeof dRho === 'number') ? dRho : 600,
      dp_um: (typeof dp_um === 'number') ? dp_um : 10,
      color: SUBSTANCE_COLOR,
      lastSign: 0,
      accumulation: 0,
      particles: []
    };
    SIM.substance = sub;
    buildSubstanceParticles(sub);
    return sub;
  }

  function buildSubstanceParticles(sub){
    var holder = document.getElementById('particleHolder');
    var eq = currentEquipmentInputs();
    var lim = limits(eq.r);
    var col = particleColor(sub.dRho, sub.color);
    var rad = particleVisualRadius(sub.dp_um);

    for (var i=0; i<N_PARTICLES; i++){
      var el = document.createElement('a-entity');
      el.setAttribute('geometry', 'primitive: sphere; radius: ' + rad + '; segmentsWidth:10; segmentsHeight:8');
      el.setAttribute('material', 'color:'+col+'; shader:flat');
      holder.appendChild(el);

      var radius = lim.inner + Math.random()*(lim.outer-lim.inner)*0.8;
      var angle = Math.random()*Math.PI*2;
      var y = (Math.random()-0.5) * lim.height * 0.8;

      var state = { radius: radius, angle: angle, y: y, el: el, arrived: false };
      sub.particles.push(state);
      placeParticle(state);
    }

    var fluidHolder = document.getElementById('rig');
    var wall = document.createElement('a-entity');
    wall.setAttribute('geometry', 'primitive: cylinder; openEnded:true; segmentsRadial:28');
    wall.setAttribute('material', 'color:'+col+'; opacity:0; transparent:true; side:double; shader:flat');
    fluidHolder.appendChild(wall);

    var core = document.createElement('a-entity');
    core.setAttribute('geometry', 'primitive: cylinder; openEnded:true; segmentsRadial:16');
    core.setAttribute('material', 'color:'+col+'; opacity:0; transparent:true; side:double; shader:flat');
    fluidHolder.appendChild(core);

    sub.wallEl = wall;
    sub.coreEl = core;
    updateSubstanceRingGeometry(sub, eq.r);
  }

  function updateSubstanceRingGeometry(sub, r){
    var h = r * 1.3;
    if (sub.wallEl) sub.wallEl.setAttribute('geometry', 'primitive: cylinder; radius: ' + (r*0.97) + '; height: ' + h + '; openEnded: true; segmentsRadial: 28');
    if (sub.coreEl) sub.coreEl.setAttribute('geometry', 'primitive: cylinder; radius: ' + (r*0.12) + '; height: ' + h + '; openEnded: true; segmentsRadial: 16');
  }

  function placeParticle(p){
    var x = p.radius * Math.cos(p.angle);
    var z = p.radius * Math.sin(p.angle);
    p.el.object3D.position.set(x, p.y, z);
  }

  function recolorSubstanceParticles(sub){
    var col = particleColor(sub.dRho, sub.color);
    for (var i=0;i<sub.particles.length;i++){
      sub.particles[i].el.setAttribute('material', 'color:'+col+'; shader:flat');
    }
    if (sub.wallEl) sub.wallEl.setAttribute('material', 'color:'+col+'; opacity:0; transparent:true; side:double; shader:flat');
    if (sub.coreEl) sub.coreEl.setAttribute('material', 'color:'+col+'; opacity:0; transparent:true; side:double; shader:flat');
  }

  // reinicia las partículas a posiciones aleatorias y las pone a migrar de nuevo
  function resetSubstanceParticles(sub){
    var eq = currentEquipmentInputs();
    var lim = limits(eq.r);
    for (var i=0;i<sub.particles.length;i++){
      var p = sub.particles[i];
      p.radius = lim.inner + Math.random()*(lim.outer-lim.inner)*0.8;
      p.angle = Math.random()*Math.PI*2;
      p.y = (Math.random()-0.5) * lim.height * 0.8;
      p.arrived = false;
      placeParticle(p);
    }
    sub.accumulation = 0;
    updateSubstanceAccumulationVisual(sub, 0);
    SIM.finished = false;
    repeatBtn.hidden = true;
  }

  function updateSubstanceAccumulationVisual(sub, level){
    if (!sub.wallEl || !sub.coreEl) return;
    if (Math.abs(sub.dRho) < 5){
      sub.wallEl.setAttribute('material', 'opacity', 0);
      sub.coreEl.setAttribute('material', 'opacity', 0);
    } else if (sub.dRho > 0){
      sub.wallEl.setAttribute('material', 'opacity', level*0.85);
      sub.coreEl.setAttribute('material', 'opacity', 0);
    } else {
      sub.coreEl.setAttribute('material', 'opacity', level*0.85);
      sub.wallEl.setAttribute('material', 'opacity', 0);
    }
  }

  // ---------------- Componente A-Frame: motor de la simulación ----------------
  AFRAME.registerComponent('centrifuge-sim', {
    init: function(){
      updateDrumGeometry(parseFloat(rSlider.value));
      createSubstance(parseFloat(dRhoSlider.value), parseFloat(dpSlider.value));
      updateReadouts();
    },

    tick: function(time, timeDelta){
      if (!timeDelta) return;

      var light = document.getElementById('statusLight');
      if (SIM.paused){
        light.setAttribute('material', 'opacity', 0.22);
        light.setAttribute('light', 'intensity', 0.08);
      } else {
        var pulse = 0.5 + 0.4*Math.sin(time/170);
        light.setAttribute('material', 'opacity', pulse);
        light.setAttribute('light', 'intensity', 0.15 + pulse*0.4);
      }

      if (SIM.paused) return;

      var dt = Math.min(timeDelta, 50) / 1000;
      var eq = currentEquipmentInputs();
      var mu_pas = eq.mu_mpas * 1e-3;
      var og = computeOmegaG(eq.rpm, eq.r);
      var lim = limits(eq.r);

      var angularVis = (og.omega / ANGULAR_VIS_SCALE);

      // El tambor SIEMPRE gira mientras no esté en pausa,
      // incluso cuando la sedimentación ya terminó.
      var rotor = document.getElementById('drumRotor');
      rotor.object3D.rotation.y += angularVis * dt;

      // Las partículas solo migran si la simulación no ha finalizado
      if (SIM.finished) { updateReadouts(); return; }

      var sub = SIM.substance;
      if (!sub) { updateReadouts(); return; }

      var dp_m = sub.dp_um * 1e-6;
      var vt = computeVt(og.omega, eq.r, sub.dRho, dp_m, mu_pas);

      // Velocidad radial visual: escalada de v_t real, con piso y techo
      // para que siempre sea perceptible pero nunca instantánea.
      var radialSign = vt >= 0 ? 1 : -1;
      var radialVis = Math.abs(sub.dRho) >= 5
        ? radialSign * clamp(Math.abs(vt) * SPEED_VIS_SCALE, RADIAL_VIS_MIN, RADIAL_VIS_MAX)
        : 0;

      var anyArrived = false;
      var allArrived = true;

      for (var i=0; i<sub.particles.length; i++){
        var p = sub.particles[i];
        if (p.arrived){ continue; }

        p.angle += angularVis * dt;

        if (Math.abs(sub.dRho) >= 5){
          p.radius += radialVis * dt;

          if (sub.dRho > 0 && p.radius >= lim.outer){
            p.radius = lim.outer;
            p.arrived = true;
            anyArrived = true;
          } else if (sub.dRho < 0 && p.radius <= lim.inner){
            p.radius = lim.inner;
            p.arrived = true;
            anyArrived = true;
          }
        } else {
          // Δρ ≈ 0: no hay migración neta, la partícula nunca "llega"
          allArrived = false;
        }

        p.radius = clamp(p.radius, lim.inner, lim.outer);
        placeParticle(p);

        if (!p.arrived) allArrived = false;
      }

      if (anyArrived){
        sub.accumulation = Math.min(1, sub.accumulation + 0.012);
        updateSubstanceAccumulationVisual(sub, sub.accumulation);
      }

      if (allArrived && Math.abs(sub.dRho) >= 5 && !SIM.finished){
        SIM.finished = true;
        SIM.paused = true;
        pauseBtn.classList.add('is-paused');
        pauseLabel.textContent = 'Reanudar';
        repeatBtn.hidden = false;
      }

      updateReadouts();
    }
  });

  // ---------------- Eventos de UI: equipo ----------------
  bindSliderNumberPair(rpmSlider, rpmInput, updateReadouts);
  bindSliderNumberPair(muSlider, muInput, updateReadouts);

  bindSliderNumberPair(rSlider, rInput, function(){
    updateDrumGeometry(parseFloat(rSlider.value));
    updateReadouts();
  });

  // ---------------- Eventos de UI: partícula / sustancia ----------------
  bindSliderNumberPair(dRhoSlider, dRhoInput, function(){
    var sub = SIM.substance;
    if (!sub) return;
    var v = parseFloat(dRhoSlider.value);
    sub.dRho = v;
    dRhoLive.textContent = v.toFixed(0);
    var sign = v >= 5 ? 1 : (v <= -5 ? -1 : 0);
    if (sign !== sub.lastSign){
      sub.lastSign = sign;
      recolorSubstanceParticles(sub);
      resetSubstanceParticles(sub);
    }
    updateReadouts();
  });

  bindSliderNumberPair(dpSlider, dpInput, function(){
    var sub = SIM.substance;
    if (!sub) return;
    var v = parseFloat(dpSlider.value);
    sub.dp_um = v;
    dpLive.textContent = v.toFixed(0);
    applyParticleSize(sub);
    updateReadouts();
  });

  // ---------------- Controles de reproducción ----------------
  pauseBtn.addEventListener('click', function(){
    SIM.paused = !SIM.paused;
    pauseBtn.classList.toggle('is-paused', SIM.paused);
    pauseLabel.textContent = SIM.paused ? 'Reanudar' : 'Pausa';
  });

  resetBtn.addEventListener('click', function(){
    if (SIM.substance) resetSubstanceParticles(SIM.substance);
  });

  repeatBtn.addEventListener('click', function(){
    if (!SIM.substance) return;
    resetSubstanceParticles(SIM.substance);
    SIM.paused = false;
    pauseBtn.classList.remove('is-paused');
    pauseLabel.textContent = 'Pausa';
  });

  // ---------------- Vista lateral (modelo 3D sin marcador) ----------------
  // Al activarse, el nodo #rig (con todo el equipo y las partículas) se
  // reubica del interior de <a-marker> al contenedor estático
  // #staticViewHolder, con un ángulo lateral fijo que puede rotarse con
  // el dedo o el mouse. La lógica de simulación (centrifuge-sim, tick,
  // partículas) no cambia: sigue operando sobre el mismo nodo #rig, solo
  // que ahora su transform ya no depende del tracking AR del marcador.
  var lateralActive = false;
  var lateralDrag = { active:false, lastX:0, lastY:0 };
  var lateralRotation = { x: 8, y: 35 };

  function setStaticHolderRotation(){
    staticViewHolder.setAttribute('rotation', lateralRotation.x + ' ' + lateralRotation.y + ' 0');
  }

  sideViewBtn.addEventListener('click', function(){
    var rig = document.getElementById('rig');
    lateralActive = !lateralActive;
    sideViewBtn.classList.toggle('active', lateralActive);
    sideViewLabel.textContent = lateralActive ? 'Modo AR' : 'Vista lateral';
    lateralHint.classList.toggle('show', lateralActive);

    if (lateralActive){
      staticViewHolder.appendChild(rig);
      staticViewHolder.setAttribute('visible', 'true');
      setStaticHolderRotation();
      markerHint.style.opacity = '0';
      markerHint.style.pointerEvents = 'none';
    } else {
      hiroMarkerEl.appendChild(rig);
      staticViewHolder.setAttribute('visible', 'false');
      // el listener markerFound/markerLost restaura el aviso del marcador
      markerHint.style.opacity = '1';
      markerHint.style.pointerEvents = 'auto';
    }
  });

  // arrastrar (mouse/touch) para rotar el equipo en vista lateral
  function lateralDragStart(x, y){
    if (!lateralActive) return;
    lateralDrag.active = true;
    lateralDrag.lastX = x;
    lateralDrag.lastY = y;
  }
  function lateralDragMove(x, y){
    if (!lateralActive || !lateralDrag.active) return;
    var dx = x - lateralDrag.lastX;
    var dy = y - lateralDrag.lastY;
    lateralDrag.lastX = x;
    lateralDrag.lastY = y;
    lateralRotation.y += dx * 0.35;
    lateralRotation.x = Math.max(-40, Math.min(60, lateralRotation.x - dy * 0.25));
    setStaticHolderRotation();
  }
  function lateralDragEnd(){ lateralDrag.active = false; }

  sceneEl.addEventListener('mousedown', function(e){ lateralDragStart(e.clientX, e.clientY); });
  window.addEventListener('mousemove', function(e){ lateralDragMove(e.clientX, e.clientY); });
  window.addEventListener('mouseup', lateralDragEnd);
  sceneEl.addEventListener('touchstart', function(e){
    if (!lateralActive) return;
    var t = e.touches[0]; lateralDragStart(t.clientX, t.clientY);
  }, { passive:true });
  sceneEl.addEventListener('touchmove', function(e){
    if (!lateralActive) return;
    var t = e.touches[0]; lateralDragMove(t.clientX, t.clientY);
  }, { passive:true });
  sceneEl.addEventListener('touchend', lateralDragEnd);

  panelToggle.addEventListener('click', function(){
    var collapsed = panelBody.classList.toggle('collapsed');
    panelToggle.classList.toggle('is-collapsed', collapsed);
    panelToggleLabel.textContent = collapsed ? 'Controles' : 'Ocultar';
  });

  advToggle.addEventListener('click', function(){
    var open = advPanel.classList.toggle('open');
    advToggle.classList.toggle('open', open);
  });

  // ---------------- Barra lateral: navegación vertical entre secciones ----------------
  var sections = Array.prototype.map.call(sideNavBtns, function(btn){
    return { btn: btn, el: document.getElementById(btn.getAttribute('data-target')) };
  });

  sideNavBtns.forEach(function(btn){
