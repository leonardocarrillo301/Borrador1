  // ---------------- Calculadora de centrifugación ----------------
  var calcBtn = document.getElementById('calcBtn');
  var calcResults = document.getElementById('calcResults');
  var calcError   = document.getElementById('calcError');

  calcBtn.addEventListener('click', function(){
    calcError.style.display = 'none';
    calcResults.classList.remove('visible');

    var rhoP = parseFloat(document.getElementById('c_rhoP').value);
    var rhoF = parseFloat(document.getElementById('c_rhoF').value);
    var dp_um = parseFloat(document.getElementById('c_dp').value);
    var rpm  = parseFloat(document.getElementById('c_rpm').value);
    var r    = parseFloat(document.getElementById('c_r').value);
    var mu_mpas = parseFloat(document.getElementById('c_mu').value);

    if ([rhoP,rhoF,dp_um,rpm,r,mu_mpas].some(function(v){ return isNaN(v) || v <= 0; })){
      calcError.textContent = 'Por favor ingresa valores positivos en todos los campos.';
      calcError.style.display = 'block';
      return;
    }

    var dRho   = rhoP - rhoF;                        // kg/m³
    var dp_m   = dp_um * 1e-6;                        // m
    var mu_pas = mu_mpas * 1e-3;                      // Pa·s
    var omega  = (rpm * 2 * Math.PI) / 60;            // rad/s
    var G      = (omega * omega * r) / G_GRAV;        // adim

    var vt = (dp_m*dp_m * dRho * omega*omega * r) / (18 * mu_pas);  // m/s (con signo)
    var vt_mm = vt * 1000;                            // mm/s

    // Re de partícula para verificar validez de Stokes
    // Re = rhoF * |vt| * dp / mu
    var Re = (rhoF * Math.abs(vt) * dp_m) / mu_pas;

    // Tiempo de sedimentación por integración exacta de Stokes-centrífuga:
    // t = [18μ / (dp² · Δρ · ω²)] · ln(r_o / r_i)
    // r_i = r*0.10, r_o = r*0.93 (límites del tambor)
    var r_i = r * 0.10, r_o = r * 0.93;
    var t_sed_s = null;
    var t_sed_str = '—', t_sed_unit_str = '';
    if (Math.abs(dRho) >= 1 && Math.abs(vt) > 1e-15){
      var K = (18 * mu_pas) / (dp_m*dp_m * Math.abs(dRho) * omega*omega);
      t_sed_s = K * Math.log(r_o / r_i);
      // elegir unidad adecuada
      if (t_sed_s < 60){
        t_sed_str = t_sed_s.toFixed(3);
        t_sed_unit_str = 's';
      } else if (t_sed_s < 3600){
        t_sed_str = (t_sed_s/60).toFixed(3);
        t_sed_unit_str = 'min';
      } else {
        t_sed_str = (t_sed_s/3600).toFixed(3);
        t_sed_unit_str = 'h';
      }
    } else {
      t_sed_str = 'Δρ ≈ 0 · sin separación';
      t_sed_unit_str = '';
    }

    document.getElementById('co_omega').textContent = omega.toFixed(3);
    document.getElementById('co_G').textContent     = G.toFixed(3);
    document.getElementById('co_dRho').textContent  = dRho.toFixed(3);
    document.getElementById('co_vt').textContent    = vt_mm.toFixed(3);
    document.getElementById('co_Re').textContent    = Re.toExponential(3);
    document.getElementById('co_tsed').textContent  = t_sed_str;
    document.getElementById('co_tsed_unit').textContent = t_sed_unit_str;

    // Aviso si Re > 0.5 (Stokes puede no ser válido)
    var reBadge = document.getElementById('co_Re');
    reBadge.style.color = Re < 0.5 ? 'var(--blue)' : '#ffb347';

    calcResults.classList.add('visible');
  });

  // ---------------- Aviso de detección de marcador ----------------
  var markerEl = document.getElementById('hiroMarker');
  markerEl.addEventListener('markerFound', function(){
    markerHint.style.opacity = '0';
    markerHint.style.pointerEvents = 'none';
  });
  markerEl.addEventListener('markerLost', function(){
    if (lateralActive) return; // en vista lateral el aviso de marcador permanece oculto
    markerHint.style.opacity = '1';
    markerHint.style.pointerEvents = 'auto';
  });

})();
</script>

</body>
</html>
