  function highlightActiveSection(){
    var scrollPos = panelScroll.scrollTop + 12;
    var activeEl = sections[0] && sections[0].el;
    sections.forEach(function(s){
      if (s.el && s.el.offsetTop <= scrollPos) activeEl = s.el;
